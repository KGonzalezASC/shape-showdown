# Optional overrides (config files are the main source of truth):
# PORT=3000
# SERVE_CLIENT=true
#
# Socket.IO target (static page on 443, game server on another port on same host):
# Either set in public/game-config.json (copied to dist) after deploy, or at build time:
# VITE_GAME_SERVER_URL=https://skillcade.example.com:10106
# VITE_GAME_SERVER_PORT=10106
# VITE_GAME_SERVER_HOST=skillcade.example.com
#
# Optional if config/client.json is missing / base is "/":
# Optional override for Vite asset base (normally set in config/client.json).
# Use ./ for subdirectory/embed deploys (assets relative to index.html).
# VITE_BASE_URL=./

# Local split-mode dev example (Vite client on 5173, server on 3000):
# VITE_GAME_SERVER_URL=http://localhost:3000
